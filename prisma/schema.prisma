generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  name          String?
  password      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  resignations  Resignation[]
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Resignation {
  id                String            @id @default(cuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName       String
  companyEmail      String
  companyAddress    String?
  recipientName     String?

  resignationDate   DateTime
  lastWorkingDate   DateTime
  resignationReason ResignationReason @default(PERSONAL)
  customReason      String?

  paidLeave         PaidLeaveOption   @default(FULL)
  equipmentReturn   EquipmentOption   @default(BY_MAIL)
  documentDelivery  DocumentOption    @default(BY_MAIL)

  sendMethod        SendMethod        @default(COPY_PASTE)
  senderEmail       String?
  scheduledAt       DateTime?

  generatedEmail    String?
  generatedSubject  String?
  generatedLetter   String?

  status            ResignationStatus @default(DRAFT)
  emailSentAt       DateTime?
  postalSentAt      DateTime?
  postalTrackingId  String?

  paymentStatus     PaymentStatus     @default(PENDING)
  stripeSessionId   String?
  paidAt            DateTime?

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  replies           Reply[]
  checklistItems    ChecklistItem[]
}

model Reply {
  id               String      @id @default(cuid())
  resignationId    String
  resignation      Resignation @relation(fields: [resignationId], references: [id], onDelete: Cascade)

  rawContent       String
  summary          String?
  hasKeywords      Boolean     @default(false)
  detectedKeywords String[]
  fromEmail        String
  fromName         String?
  subject          String
  receivedAt       DateTime    @default(now())
  isRead           Boolean     @default(false)

  createdAt        DateTime    @default(now())
}

model ChecklistItem {
  id            String      @id @default(cuid())
  resignationId String
  resignation   Resignation @relation(fields: [resignationId], references: [id], onDelete: Cascade)

  title         String
  description   String
  dueDate       DateTime?
  category      String
  isCompleted   Boolean     @default(false)
  completedAt   DateTime?
  notifyAt      DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum ResignationReason {
  PERSONAL
  OTHER
}

enum PaidLeaveOption {
  FULL
  NEGOTIATE
  NONE
}

enum EquipmentOption {
  BY_MAIL
  AT_DESK
  IN_PERSON
}

enum DocumentOption {
  BY_MAIL
  NONE
}

enum SendMethod {
  SMTP
  OAUTH
  COPY_PASTE
}

enum ResignationStatus {
  DRAFT
  READY
  EMAIL_SENT
  POSTAL_SENT
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}
